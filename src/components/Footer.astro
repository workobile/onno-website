---
const PROJECT_ID = import.meta.env.SANITY_PROJECT_ID ?? "";
const DATASET = import.meta.env.SANITY_DATASET ?? "production";
const API_VERSION = import.meta.env.SANITY_API_VERSION ?? "2024-01-01";

const DEFAULT_SETTINGS = {
  email: "hello@example.com",
  instagram: null as string | null,
  linkedin: null as string | null,
  footerTagline: "Theatrical models, set design & lighting for contemporary performance spaces.",
};

let settings = DEFAULT_SETTINGS;
try {
  const query = encodeURIComponent(
    `*[_type == "siteSettings"][0]{ email, instagram, linkedin, footerTagline }`
  );
  const res = await fetch(
    `https://${PROJECT_ID}.api.sanity.io/v${API_VERSION}/data/query/${DATASET}?query=${query}`
  );
  if (res.ok) {
    const json = await res.json();
    if (json.result) settings = { ...DEFAULT_SETTINGS, ...json.result };
  }
} catch {}

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/work", label: "Work" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/impressum", label: "Impressum" },
];
---

<footer class="bg-black border-t border-white/10 py-16 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-white text-3xl uppercase tracking-wider font-bold mb-4 inline-block">
          O<span class="text-red-500">N</span>
        </a>
        <p class="text-white/40 text-sm font-mono uppercase tracking-wider mt-4 max-w-xs">
          {settings.footerTagline}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white/40 text-xs uppercase tracking-widest font-mono mb-6">Navigation</h3>
        <ul class="space-y-3">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/70 hover:text-red-500 text-sm uppercase tracking-widest transition-colors duration-200 hover:[text-shadow:0_0_15px_rgba(239,68,68,0.6)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social & Contact -->
      <div>
        <h3 class="text-white/40 text-xs uppercase tracking-widest font-mono mb-6">Connect</h3>
        <div class="space-y-4">
          <a
            href={`mailto:${settings.email}`}
            class="flex items-center gap-3 text-white/70 hover:text-red-500 transition-colors duration-200 group"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:[filter:drop-shadow(0_0_8px_rgba(239,68,68,0.8))]">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <span class="text-sm font-mono">{settings.email}</span>
          </a>
          {settings.instagram && (
            <a
              href={`https://instagram.com/${settings.instagram.replace("@", "")}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-white/70 hover:text-red-500 transition-colors duration-200 group"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:[filter:drop-shadow(0_0_8px_rgba(239,68,68,0.8))]">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
              </svg>
              <span class="text-sm font-mono">@{settings.instagram.replace("@", "")}</span>
            </a>
          )}
          {settings.linkedin && (
            <a
              href={settings.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-white/70 hover:text-red-500 transition-colors duration-200 group"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:[filter:drop-shadow(0_0_8px_rgba(239,68,68,0.8))]">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect width="4" height="12" x="2" y="9"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
              <span class="text-sm font-mono">LinkedIn</span>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs font-mono uppercase tracking-widest">
        &copy; {currentYear} Stage Designer. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/impressum"
          class="text-white/30 hover:text-red-500 text-xs font-mono uppercase tracking-widest transition-colors duration-200"
        >
          Impressum
        </a>
        <span class="text-white/10">|</span>
        <a
          href="https://kunsttech.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/20 hover:text-red-500 text-xs font-mono uppercase tracking-widest transition-colors duration-200"
        >
          Developed by Kunsttech
        </a>
      </div>
    </div>
  </div>
</footer>
