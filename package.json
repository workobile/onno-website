{
  "name": "onno-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "postbuild": "node -e \"require('fs').writeFileSync('dist/.assetsignore', '_worker.js\\n')\"",
    "preview": "npm run build && wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name onno-website",
    "sanity:dev": "cd sanity && node --env-file=../.env node_modules/sanity/bin/sanity dev",
    "sanity:prod": "cd sanity && node --env-file=../.env node_modules/sanity/bin/sanity deploy",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^11.0.0",
    "@astrojs/react": "^3.6.0",
    "@astrojs/tailwind": "^5.1.0",
    "@fontsource/barlow-condensed": "^5.0.0",
    "@fontsource/inter": "^5.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "astro": "^4.15.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.400.0",
    "motion": "^11.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-responsive-masonry": "^2.7.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  }
}
